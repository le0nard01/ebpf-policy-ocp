FROM registry.access.redhat.com/ubi9/ubi:latest AS builder

RUN dnf install -y --enablerepo=codeready-builder-for-rhel-9-x86_64-rpms \
        clang \
        llvm \
        make \
        kernel-headers \
        elfutils-libelf-devel \
        libbpf-devel && \
    dnf clean all

WORKDIR /src
COPY code ./code
COPY build ./build

ARG TARGET_ARCH=x86
RUN make -C build build TARGET_ARCH=${TARGET_ARCH}

FROM scratch
COPY --from=builder /output/program.bpf.o /program.bpf.o
